{# =====================================================================
   DeepSeek-V4 chat template — with tool (function) calling.

   Faithful to the format the model was trained on (verified against the
   GGUF's tokenizer.chat_template): byte-identical output, just reformatted
   and commented. Tool calls use an XML scheme on the ｜DSML｜ special token;
   tool results are fed back inside a user turn as <tool_result>…</tool_result>.

   Inputs:
     messages              list of {role, content, [reasoning_content], [tool_calls]}
                           role ∈ {system, user, assistant, tool}
     tools                 optional list of {type:"function",
                                             function:{name,description,parameters}}
     add_generation_prompt bool — open an assistant turn at the end (default false)
     thinking / enable_thinking  bool — open the reasoning block <think> (default false)

   Special tokens: bos_token=<｜begin▁of▁sentence｜>, <｜end▁of▁sentence｜>,
   <｜User｜>, <｜Assistant｜>, <think>, </think>, ｜DSML｜.

   NOTE: the tool-header is built with explicit '\n' concatenation (not a
   {% set %}…{% endset %} block) so the output does NOT depend on the host
   engine's Jinja whitespace settings (trim_blocks / lstrip_blocks).
   ===================================================================== #}

{%- if not add_generation_prompt is defined -%}
  {%- set add_generation_prompt = false -%}
{%- endif -%}
{%- if not thinking is defined -%}
  {%- if enable_thinking is defined -%}
    {%- set thinking = enable_thinking -%}
  {%- else -%}
    {%- set thinking = false -%}
  {%- endif -%}
{%- endif -%}

{%- set dsml = '｜DSML｜' -%}
{%- set think_open = '<think>' -%}
{%- set think_close = '</think>' -%}

{#- Tool-declaration block, appended to the system prompt when tools are present.
    Ends with "### Available Tool Schemas\n\n"; the per-tool JSON schemas and the
    footer are appended after it below. -#}
{%- set tools_header = '## Tools\n\n'
    + 'You have access to a set of tools to help answer the user question. '
    + 'You can invoke tools by writing a "<' + dsml + 'tool_calls>" block like the following:\n\n'
    + '<' + dsml + 'tool_calls>\n'
    + '<' + dsml + 'invoke name="$TOOL_NAME">\n'
    + '<' + dsml + 'parameter name="$PARAMETER_NAME" string="true|false">$PARAMETER_VALUE</' + dsml + 'parameter>\n'
    + '...\n'
    + '</' + dsml + 'invoke>\n'
    + '<' + dsml + 'invoke name="$TOOL_NAME2">\n'
    + '...\n'
    + '</' + dsml + 'invoke>\n'
    + '</' + dsml + 'tool_calls>\n\n'
    + 'String parameters should be specified as is and set `string="true"`. '
    + 'For all other types (numbers, booleans, arrays, objects), pass the value '
    + 'in JSON format and set `string="false"`.\n\n'
    + 'If thinking_mode is enabled (triggered by ' + think_open + '), you MUST output your '
    + 'complete reasoning inside ' + think_open + '...' + think_close + ' BEFORE any tool calls '
    + 'or final response.\n\n'
    + 'Otherwise, output directly after ' + think_close + ' with tool calls or final response.\n\n'
    + '### Available Tool Schemas\n\n' -%}
{%- set tools_footer = '\n\nYou MUST strictly follow the above defined tool name and parameter schemas to invoke tool calls.' -%}

{#- Collect the system prompt(s): first verbatim, the rest joined with a blank line. -#}
{%- set ns = namespace(system='', is_first_system=true, pending_assistant=false, pending_tool_result=false) -%}
{%- for message in messages -%}
  {%- if message['role'] == 'system' -%}
    {%- if ns.is_first_system -%}
      {%- set ns.system = ns.system + (message['content'] or '') -%}
      {%- set ns.is_first_system = false -%}
    {%- else -%}
      {%- set ns.system = ns.system + '\n\n' + (message['content'] or '') -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{#- Append the tool declarations (header + per-tool schemas + footer). -#}
{%- if tools is defined and tools -%}
  {%- set ts = namespace(schemas='') -%}
  {%- for tool in tools -%}
    {%- if tool['type'] == 'function' -%}
      {%- set ts.schemas = ts.schemas + (tool['function'] | tojson) + '\n' -%}
    {%- endif -%}
  {%- endfor -%}
  {%- set tools_block = tools_header + ts.schemas + tools_footer -%}
  {%- if ns.system -%}
    {%- set ns.system = ns.system + '\n\n' + tools_block -%}
  {%- else -%}
    {%- set ns.system = tools_block -%}
  {%- endif -%}
{%- endif -%}

{#- BOS + system (no separator: system is glued to the BOS). -#}
{{- bos_token -}}
{{- ns.system -}}

{#- The turns. pending_assistant marks that an assistant reply is expected next;
    pending_tool_result avoids repeating <｜User｜> for consecutive tool results. -#}
{%- for message in messages -%}
  {%- if message['role'] == 'user' -%}
    {{- '<｜User｜>' + (message['content'] or '') -}}
    {%- set ns.pending_assistant = true -%}
    {%- set ns.pending_tool_result = false -%}

  {%- elif message['role'] == 'tool' -%}
    {%- if not ns.pending_tool_result -%}
      {{- '<｜User｜>' -}}
    {%- endif -%}
    {{- '<tool_result>' + (message['content'] or '') + '</tool_result>' -}}
    {%- set ns.pending_assistant = true -%}
    {%- set ns.pending_tool_result = true -%}

  {%- elif message['role'] == 'assistant' -%}
    {%- if ns.pending_assistant -%}
      {{- '<｜Assistant｜>' -}}
      {#- Keep the reasoning trace only when thinking is on AND it is provided
          (interleaved thinking across tool rounds); otherwise just </think>. -#}
      {%- if thinking and message['reasoning_content'] is defined and message['reasoning_content'] -%}
        {{- think_open + message['reasoning_content'] + think_close -}}
      {%- else -%}
        {{- think_close -}}
      {%- endif -%}
    {%- endif -%}
    {{- (message['content'] or '') -}}
    {%- if message['tool_calls'] -%}
      {{- '\n\n<' + dsml + 'tool_calls>\n' -}}
      {%- for tool in message['tool_calls'] -%}
        {%- set func = tool['function'] -%}
        {{- '<' + dsml + 'invoke name="' + func['name'] + '">\n' -}}
        {%- set args = func['arguments'] -%}
        {%- if args is string -%}
          {%- set args = args | from_json -%}
        {%- endif -%}
        {%- for key, val in args.items() -%}
          {%- if val is string -%}
            {{- '<' + dsml + 'parameter name="' + key + '" string="true">' + val + '</' + dsml + 'parameter>\n' -}}
          {%- else -%}
            {{- '<' + dsml + 'parameter name="' + key + '" string="false">' + (val | tojson) + '</' + dsml + 'parameter>\n' -}}
          {%- endif -%}
        {%- endfor -%}
        {{- '</' + dsml + 'invoke>\n' -}}
      {%- endfor -%}
      {{- '</' + dsml + 'tool_calls>' -}}
    {%- endif -%}
    {{- '<｜end▁of▁sentence｜>' -}}
    {%- set ns.pending_assistant = false -%}
    {%- set ns.pending_tool_result = false -%}
  {%- endif -%}
{%- endfor -%}

{#- Open the assistant turn for generation. -#}
{%- if add_generation_prompt and ns.pending_assistant -%}
  {{- '<｜Assistant｜>' -}}
  {%- if thinking -%}
    {{- think_open -}}
  {%- else -%}
    {{- think_close -}}
  {%- endif -%}
{%- endif -%}
