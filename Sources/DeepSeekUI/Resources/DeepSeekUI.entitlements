<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required by the Mac App Store (validator error 90296). Without
         this, App Store Connect rejects the .pkg at upload time. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Outbound HTTP. OpenRouterAPI, WebFetchTool, WebSearchTool, and
         the HTTP/SSE MCP transports all go through URLSession; without
         this entitlement they fail with NSURLErrorDomain -1003 / -1004
         inside the sandbox. -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- NSOpenPanel-selected files. Used everywhere the user picks a
         path on disk: weights directory (ContentView, ModelState),
         document imports (DocumentLibrary, ImportDocumentSheet),
         project roots (ProjectDetailView, ProjectInventory), converter
         / fine-tune / vocab-pruner source folders, and MCP server
         binary lookups. The sandbox extends read+write access to each
         user-selected URL for the lifetime of the process. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Re-open user-selected paths across launches via security-scoped
         bookmarks. The model loader, project library, and document
         library all persist URLs in their JSON state under Application
         Support; without this entitlement bookmark resolution fails
         silently and the user has to re-pick the folder every launch. -->
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>
</dict>
</plist>
